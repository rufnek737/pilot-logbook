{
  "appId": "com.rufnek.pilotlogbook",
  "appName": "Pilot Logbook",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0a1440",
    "overScrollMode": "never"
  },
  "ios": {
    "backgroundColor": "#0a1440",
    "contentInset": "automatic",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#0a1440",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a1440"
    }
  }
}