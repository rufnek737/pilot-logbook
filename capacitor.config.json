{
  "appId": "com.rufnek.pilotlogbook",
  "appName": "Pilot Logbook",
  "webDir": "www",
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0a1440",
    "overScrollMode": "never"
  },
  "ios": {
    "backgroundColor": "#0a1440",
    "contentInset": "never",
    "scrollEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#0a1440",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a1440",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "none"
    },
    "GoogleAuth": {
      "serverClientId": "824870554939-vicqc3fpdmo2b4n14ot8hegjqn97uvb5.apps.googleusercontent.com"
    }
  }
}
